{
  "$defs": {
    "CaptionPreset": {
      "description": "Именованный пресет стиля субтитров (мини brand kit, спека §9).",
      "properties": {
        "highlight": {
          "anyOf": [
            {
              "$ref": "#/$defs/HighlightStyle"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "style": {
          "$ref": "#/$defs/CaptionStyle"
        }
      },
      "required": [
        "id",
        "name",
        "style"
      ],
      "type": "object"
    },
    "CaptionReply": {
      "description": "Одна реплика субтитра (чанк 3–5 слов).",
      "properties": {
        "emphasis_refs": {
          "items": {
            "type": "integer"
          },
          "type": "array"
        },
        "hidden": {
          "default": false,
          "type": "boolean"
        },
        "text_override": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "word_refs": {
          "items": {
            "type": "integer"
          },
          "type": "array"
        }
      },
      "required": [
        "word_refs"
      ],
      "type": "object"
    },
    "CaptionStyle": {
      "description": "Стиль субтитров. Компилируется в ASS (рендер) и в CSS (превью) из одной модели.",
      "properties": {
        "alignment": {
          "default": 2,
          "type": "integer"
        },
        "box_color": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "box_opacity": {
          "default": 0.0,
          "maximum": 1.0,
          "minimum": 0.0,
          "type": "number"
        },
        "box_radius": {
          "default": 0,
          "type": "integer"
        },
        "color": {
          "default": "#FFFFFF",
          "type": "string"
        },
        "emphasis_auto": {
          "default": true,
          "type": "boolean"
        },
        "emphasis_color": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "font": {
          "default": "Montserrat",
          "type": "string"
        },
        "margin_v": {
          "default": 260,
          "type": "integer"
        },
        "outline_color": {
          "default": "#000000",
          "type": "string"
        },
        "outline_w": {
          "default": 6,
          "type": "integer"
        },
        "shadow": {
          "default": 2,
          "type": "integer"
        },
        "size": {
          "default": 90,
          "type": "integer"
        },
        "uppercase": {
          "default": true,
          "type": "boolean"
        }
      },
      "type": "object"
    },
    "CaptionTrack": {
      "description": "Трек субтитров клипа: стиль + караоке + реплики + опц. топ-текст (хук).",
      "properties": {
        "burn": {
          "default": true,
          "type": "boolean"
        },
        "highlight": {
          "anyOf": [
            {
              "$ref": "#/$defs/HighlightStyle"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "hook": {
          "anyOf": [
            {
              "$ref": "#/$defs/HookOverlay"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "replies": {
          "items": {
            "$ref": "#/$defs/CaptionReply"
          },
          "type": "array"
        },
        "style": {
          "$ref": "#/$defs/CaptionStyle"
        }
      },
      "required": [
        "style"
      ],
      "type": "object"
    },
    "Chapter": {
      "description": "Глава AI-карты видео (источник-время, секунды). Главы покрывают видео непрерывно.",
      "properties": {
        "end": {
          "type": "number"
        },
        "start": {
          "type": "number"
        },
        "summary": {
          "type": "string"
        },
        "title": {
          "type": "string"
        }
      },
      "required": [
        "start",
        "end",
        "title",
        "summary"
      ],
      "type": "object"
    },
    "ChaptersData": {
      "description": "Статус+результат генерации AI-карты (кэш data/<job>/chapters.json).",
      "properties": {
        "chapters": {
          "items": {
            "$ref": "#/$defs/Chapter"
          },
          "type": "array"
        },
        "error": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "status": {
          "enum": [
            "pending",
            "done",
            "failed"
          ],
          "type": "string"
        }
      },
      "required": [
        "status"
      ],
      "type": "object"
    },
    "Clip": {
      "description": "Внутреннее представление готового клипа (пути к артефактам + экономика).",
      "properties": {
        "captions_ass_path": {
          "type": "string"
        },
        "cost_usd": {
          "type": "number"
        },
        "crop": {
          "items": {
            "$ref": "#/$defs/CropWindow"
          },
          "type": "array"
        },
        "id": {
          "type": "string"
        },
        "latency_s": {
          "type": "number"
        },
        "output_path": {
          "type": "string"
        },
        "segment": {
          "$ref": "#/$defs/Segment"
        }
      },
      "required": [
        "id",
        "segment",
        "crop",
        "captions_ass_path",
        "output_path",
        "cost_usd",
        "latency_s"
      ],
      "type": "object"
    },
    "ClipEdit": {
      "description": "РЕЦЕПТ клипа — не-деструктивный edit-state. Версионируется (optimistic-lock).",
      "properties": {
        "aspect": {
          "default": "9:16",
          "type": "string"
        },
        "captions": {
          "$ref": "#/$defs/CaptionTrack"
        },
        "id": {
          "type": "string"
        },
        "reframe_overrides": {
          "items": {
            "$ref": "#/$defs/CropOverride"
          },
          "type": "array"
        },
        "source_intervals": {
          "items": {
            "$ref": "#/$defs/SourceInterval"
          },
          "type": "array"
        },
        "version": {
          "default": 1,
          "type": "integer"
        }
      },
      "required": [
        "id",
        "source_intervals",
        "captions"
      ],
      "type": "object"
    },
    "ClipOut": {
      "description": "Клип в ответе API. `start/end` — в координатах source (фундамент clip↔source).\n\n`words[]` присутствует уже в Phase 0 (фундамент trim-редактора), UI его игнорирует.",
      "properties": {
        "duration": {
          "type": "number"
        },
        "end": {
          "type": "number"
        },
        "hook": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "id": {
          "type": "string"
        },
        "reason": {
          "type": "string"
        },
        "score": {
          "maximum": 1,
          "minimum": 0,
          "type": "number"
        },
        "start": {
          "type": "number"
        },
        "thumbnail_url": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "transcript": {
          "type": "string"
        },
        "type": {
          "$ref": "#/$defs/ClipType"
        },
        "video_url": {
          "type": "string"
        },
        "why_works": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "words": {
          "items": {
            "$ref": "#/$defs/Word"
          },
          "type": "array"
        }
      },
      "required": [
        "id",
        "start",
        "end",
        "duration",
        "reason",
        "type",
        "score",
        "video_url",
        "transcript",
        "words"
      ],
      "type": "object"
    },
    "ClipType": {
      "description": "Тип момента, выбранного LLM (объяснимость + цвет чипа в UI).",
      "enum": [
        "hook",
        "emotional_peak",
        "complete_thought",
        "strong_quote"
      ],
      "type": "string"
    },
    "CropOverride": {
      "description": "Ручной кроп на диапазон source — поверх авто-reframe (MVP: применяется per-интервал).",
      "properties": {
        "center": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "center_b": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "mode": {
          "type": "string"
        },
        "source_end": {
          "type": "number"
        },
        "source_start": {
          "type": "number"
        }
      },
      "required": [
        "source_start",
        "source_end",
        "mode"
      ],
      "type": "object"
    },
    "CropWindow": {
      "description": "Окно кропа 9:16 в пиксельных координатах source. Phase 0: одно static-окно на клип.",
      "properties": {
        "h": {
          "type": "integer"
        },
        "t": {
          "type": "number"
        },
        "w": {
          "type": "integer"
        },
        "x": {
          "type": "integer"
        },
        "y": {
          "type": "integer"
        }
      },
      "required": [
        "t",
        "x",
        "y",
        "w",
        "h"
      ],
      "type": "object"
    },
    "HighlightStyle": {
      "description": "Караоке-подсветка активного слова. None в треке = караоке выключено.",
      "properties": {
        "animation": {
          "default": "karaoke_fill",
          "enum": [
            "none",
            "karaoke_fill",
            "pop",
            "bounce",
            "punch",
            "fade",
            "spring",
            "blur_in",
            "color_sweep"
          ],
          "type": "string"
        },
        "box": {
          "default": false,
          "type": "boolean"
        },
        "color": {
          "default": "#FFE000",
          "type": "string"
        },
        "scale": {
          "default": 1.0,
          "type": "number"
        }
      },
      "type": "object"
    },
    "HookOverlay": {
      "description": "Топ-текст (хук) клипа: цепляющий заголовок СВЕРХУ кадра (T1, наш отличитель —\nобъяснимый хук, привязанный к reason). Рендерится отдельным ASS-событием с верхним\nякорем (alignment 8) тем же libass-стеком, что субтитры → превью = экспорт, без\nвторого пайплайна. Не пересекается с нижними субтитрами.",
      "properties": {
        "animation": {
          "default": "none",
          "enum": [
            "none",
            "pop",
            "fade",
            "bounce"
          ],
          "type": "string"
        },
        "box_color": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": "#FF5A3D"
        },
        "box_opacity": {
          "default": 1.0,
          "maximum": 1.0,
          "minimum": 0.0,
          "type": "number"
        },
        "color": {
          "default": "#FFFFFF",
          "type": "string"
        },
        "duration_sec": {
          "default": 4.0,
          "type": "number"
        },
        "enabled": {
          "default": true,
          "type": "boolean"
        },
        "font": {
          "default": "Unbounded",
          "type": "string"
        },
        "full_clip": {
          "default": true,
          "type": "boolean"
        },
        "margin_v": {
          "default": 150,
          "type": "integer"
        },
        "outline_color": {
          "default": "#000000",
          "type": "string"
        },
        "outline_w": {
          "default": 4,
          "type": "integer"
        },
        "shadow": {
          "default": 0,
          "type": "integer"
        },
        "size": {
          "default": 66,
          "type": "integer"
        },
        "text": {
          "default": "",
          "type": "string"
        },
        "uppercase": {
          "default": true,
          "type": "boolean"
        }
      },
      "type": "object"
    },
    "Job": {
      "description": "Состояние задачи целиком — ответ `GET /jobs/{id}` (§4.3).",
      "properties": {
        "cancellable": {
          "default": false,
          "type": "boolean"
        },
        "clips": {
          "items": {
            "$ref": "#/$defs/ClipOut"
          },
          "type": "array"
        },
        "error": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "id": {
          "type": "string"
        },
        "metrics": {
          "anyOf": [
            {
              "$ref": "#/$defs/Metrics"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "progress": {
          "maximum": 100,
          "minimum": 0,
          "type": "integer"
        },
        "source_kind": {
          "$ref": "#/$defs/SourceKind"
        },
        "stage": {
          "$ref": "#/$defs/JobStatus"
        },
        "status": {
          "$ref": "#/$defs/JobStatus"
        }
      },
      "required": [
        "id",
        "status",
        "stage",
        "progress",
        "source_kind"
      ],
      "type": "object"
    },
    "JobStatus": {
      "description": "Состояние задачи. Им же размечаем `stage` (Phase 0: stage зеркалит status).",
      "enum": [
        "queued",
        "downloading",
        "transcribing",
        "selecting",
        "rendering",
        "done",
        "failed",
        "cancelled"
      ],
      "type": "string"
    },
    "Metrics": {
      "description": "Экономика/латентность прогона (на виду в UI).",
      "properties": {
        "cost_usd": {
          "type": "number"
        },
        "duration_sec": {
          "type": "number"
        },
        "elapsed_sec": {
          "type": "number"
        }
      },
      "required": [
        "cost_usd",
        "duration_sec",
        "elapsed_sec"
      ],
      "type": "object"
    },
    "Segment": {
      "description": "Выбранный момент (границы снэпнуты к словам). `reason` — ПОЧЕМУ, 1-2 предложения.\n\n`hook`/`why_works` (T1/T2): объяснимость как продукт — цепляющий топ-заголовок и\nразбор «почему сработает». Опциональны (default None) → старые segments.json валидны.",
      "properties": {
        "end": {
          "type": "number"
        },
        "hook": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "reason": {
          "type": "string"
        },
        "score": {
          "maximum": 1,
          "minimum": 0,
          "type": "number"
        },
        "start": {
          "type": "number"
        },
        "type": {
          "$ref": "#/$defs/ClipType"
        },
        "why_works": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "required": [
        "start",
        "end",
        "reason",
        "score",
        "type"
      ],
      "type": "object"
    },
    "SourceInterval": {
      "description": "Один оставленный кусок исходника. Интервалы упорядочены по CLIP-порядку.",
      "properties": {
        "source_end": {
          "type": "number"
        },
        "source_start": {
          "type": "number"
        }
      },
      "required": [
        "source_start",
        "source_end"
      ],
      "type": "object"
    },
    "SourceKind": {
      "description": "Откуда исходник: ссылка YouTube или загруженный файл.",
      "enum": [
        "youtube",
        "upload"
      ],
      "type": "string"
    },
    "TimelineData": {
      "description": "Данные таймлайн-редактора: длительность + ВСЕ кандидаты ИИ + пословный транскрипт.\n\nСобирается из готовых segments.json + transcript.json (без новых ИИ-вызовов).\n`words` — для hover-подсказок «что тут происходит».",
      "properties": {
        "duration": {
          "type": "number"
        },
        "segments": {
          "items": {
            "$ref": "#/$defs/TimelineSegment"
          },
          "type": "array"
        },
        "words": {
          "items": {
            "$ref": "#/$defs/Word"
          },
          "type": "array"
        }
      },
      "required": [
        "duration",
        "segments",
        "words"
      ],
      "type": "object"
    },
    "TimelineSegment": {
      "description": "Кандидат-момент ИИ на таймлайне (маркер). `clip_id`=None, если момент не стал клипом.",
      "properties": {
        "clip_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "end": {
          "type": "number"
        },
        "reason": {
          "type": "string"
        },
        "score": {
          "maximum": 1,
          "minimum": 0,
          "type": "number"
        },
        "start": {
          "type": "number"
        },
        "type": {
          "$ref": "#/$defs/ClipType"
        }
      },
      "required": [
        "start",
        "end",
        "type",
        "score",
        "reason"
      ],
      "type": "object"
    },
    "Transcript": {
      "description": "Нормализованный транскрипт. `words` отсортированы по `start`.",
      "properties": {
        "duration": {
          "type": "number"
        },
        "language": {
          "type": "string"
        },
        "words": {
          "items": {
            "$ref": "#/$defs/Word"
          },
          "type": "array"
        }
      },
      "required": [
        "language",
        "duration",
        "words"
      ],
      "type": "object"
    },
    "Word": {
      "description": "Слово с word-level таймингами (фундамент всего: субтитры, trim, маппинг).",
      "properties": {
        "confidence": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "end": {
          "type": "number"
        },
        "start": {
          "type": "number"
        },
        "text": {
          "type": "string"
        }
      },
      "required": [
        "text",
        "start",
        "end"
      ],
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "CaptionPreset": {
      "$ref": "#/$defs/CaptionPreset"
    },
    "CaptionReply": {
      "$ref": "#/$defs/CaptionReply"
    },
    "CaptionStyle": {
      "$ref": "#/$defs/CaptionStyle"
    },
    "CaptionTrack": {
      "$ref": "#/$defs/CaptionTrack"
    },
    "Chapter": {
      "$ref": "#/$defs/Chapter"
    },
    "ChaptersData": {
      "$ref": "#/$defs/ChaptersData"
    },
    "Clip": {
      "$ref": "#/$defs/Clip"
    },
    "ClipEdit": {
      "$ref": "#/$defs/ClipEdit"
    },
    "ClipOut": {
      "$ref": "#/$defs/ClipOut"
    },
    "ClipType": {
      "$ref": "#/$defs/ClipType"
    },
    "CropOverride": {
      "$ref": "#/$defs/CropOverride"
    },
    "CropWindow": {
      "$ref": "#/$defs/CropWindow"
    },
    "HighlightStyle": {
      "$ref": "#/$defs/HighlightStyle"
    },
    "HookOverlay": {
      "$ref": "#/$defs/HookOverlay"
    },
    "Job": {
      "$ref": "#/$defs/Job"
    },
    "JobStatus": {
      "$ref": "#/$defs/JobStatus"
    },
    "Metrics": {
      "$ref": "#/$defs/Metrics"
    },
    "Segment": {
      "$ref": "#/$defs/Segment"
    },
    "SourceInterval": {
      "$ref": "#/$defs/SourceInterval"
    },
    "SourceKind": {
      "$ref": "#/$defs/SourceKind"
    },
    "TimelineData": {
      "$ref": "#/$defs/TimelineData"
    },
    "TimelineSegment": {
      "$ref": "#/$defs/TimelineSegment"
    },
    "Transcript": {
      "$ref": "#/$defs/Transcript"
    },
    "Word": {
      "$ref": "#/$defs/Word"
    }
  },
  "title": "ClipFlowContract",
  "type": "object"
}
