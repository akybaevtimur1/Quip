{
  "$defs": {
    "Clip": {
      "description": "Внутреннее представление готового клипа (пути к артефактам + экономика).",
      "properties": {
        "captions_ass_path": {
          "type": "string"
        },
        "cost_usd": {
          "type": "number"
        },
        "crop": {
          "items": {
            "$ref": "#/$defs/CropWindow"
          },
          "type": "array"
        },
        "id": {
          "type": "string"
        },
        "latency_s": {
          "type": "number"
        },
        "output_path": {
          "type": "string"
        },
        "segment": {
          "$ref": "#/$defs/Segment"
        }
      },
      "required": [
        "id",
        "segment",
        "crop",
        "captions_ass_path",
        "output_path",
        "cost_usd",
        "latency_s"
      ],
      "type": "object"
    },
    "ClipOut": {
      "description": "Клип в ответе API. `start/end` — в координатах source (фундамент clip↔source).\n\n`words[]` присутствует уже в Phase 0 (фундамент trim-редактора), UI его игнорирует.",
      "properties": {
        "duration": {
          "type": "number"
        },
        "end": {
          "type": "number"
        },
        "id": {
          "type": "string"
        },
        "reason": {
          "type": "string"
        },
        "score": {
          "maximum": 1,
          "minimum": 0,
          "type": "number"
        },
        "start": {
          "type": "number"
        },
        "thumbnail_url": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "transcript": {
          "type": "string"
        },
        "type": {
          "$ref": "#/$defs/ClipType"
        },
        "video_url": {
          "type": "string"
        },
        "words": {
          "items": {
            "$ref": "#/$defs/Word"
          },
          "type": "array"
        }
      },
      "required": [
        "id",
        "start",
        "end",
        "duration",
        "reason",
        "type",
        "score",
        "video_url",
        "transcript",
        "words"
      ],
      "type": "object"
    },
    "ClipType": {
      "description": "Тип момента, выбранного LLM (объяснимость + цвет чипа в UI).",
      "enum": [
        "hook",
        "emotional_peak",
        "complete_thought",
        "strong_quote"
      ],
      "type": "string"
    },
    "CropWindow": {
      "description": "Окно кропа 9:16 в пиксельных координатах source. Phase 0: одно static-окно на клип.",
      "properties": {
        "h": {
          "type": "integer"
        },
        "t": {
          "type": "number"
        },
        "w": {
          "type": "integer"
        },
        "x": {
          "type": "integer"
        },
        "y": {
          "type": "integer"
        }
      },
      "required": [
        "t",
        "x",
        "y",
        "w",
        "h"
      ],
      "type": "object"
    },
    "Job": {
      "description": "Состояние задачи целиком — ответ `GET /jobs/{id}` (§4.3).",
      "properties": {
        "clips": {
          "items": {
            "$ref": "#/$defs/ClipOut"
          },
          "type": "array"
        },
        "error": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "id": {
          "type": "string"
        },
        "metrics": {
          "anyOf": [
            {
              "$ref": "#/$defs/Metrics"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "progress": {
          "maximum": 100,
          "minimum": 0,
          "type": "integer"
        },
        "source_kind": {
          "$ref": "#/$defs/SourceKind"
        },
        "stage": {
          "$ref": "#/$defs/JobStatus"
        },
        "status": {
          "$ref": "#/$defs/JobStatus"
        }
      },
      "required": [
        "id",
        "status",
        "stage",
        "progress",
        "source_kind"
      ],
      "type": "object"
    },
    "JobStatus": {
      "description": "Состояние задачи. Им же размечаем `stage` (Phase 0: stage зеркалит status).",
      "enum": [
        "queued",
        "downloading",
        "transcribing",
        "selecting",
        "rendering",
        "done",
        "failed"
      ],
      "type": "string"
    },
    "Metrics": {
      "description": "Экономика/латентность прогона (на виду в UI).",
      "properties": {
        "cost_usd": {
          "type": "number"
        },
        "duration_sec": {
          "type": "number"
        },
        "elapsed_sec": {
          "type": "number"
        }
      },
      "required": [
        "cost_usd",
        "duration_sec",
        "elapsed_sec"
      ],
      "type": "object"
    },
    "Segment": {
      "description": "Выбранный момент (границы снэпнуты к словам). `reason` — ПОЧЕМУ, 1-2 предложения.",
      "properties": {
        "end": {
          "type": "number"
        },
        "reason": {
          "type": "string"
        },
        "score": {
          "maximum": 1,
          "minimum": 0,
          "type": "number"
        },
        "start": {
          "type": "number"
        },
        "type": {
          "$ref": "#/$defs/ClipType"
        }
      },
      "required": [
        "start",
        "end",
        "reason",
        "score",
        "type"
      ],
      "type": "object"
    },
    "SourceKind": {
      "description": "Откуда исходник: ссылка YouTube или загруженный файл.",
      "enum": [
        "youtube",
        "upload"
      ],
      "type": "string"
    },
    "Transcript": {
      "description": "Нормализованный транскрипт. `words` отсортированы по `start`.",
      "properties": {
        "duration": {
          "type": "number"
        },
        "language": {
          "type": "string"
        },
        "words": {
          "items": {
            "$ref": "#/$defs/Word"
          },
          "type": "array"
        }
      },
      "required": [
        "language",
        "duration",
        "words"
      ],
      "type": "object"
    },
    "Word": {
      "description": "Слово с word-level таймингами (фундамент всего: субтитры, trim, маппинг).",
      "properties": {
        "confidence": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "end": {
          "type": "number"
        },
        "start": {
          "type": "number"
        },
        "text": {
          "type": "string"
        }
      },
      "required": [
        "text",
        "start",
        "end"
      ],
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "Clip": {
      "$ref": "#/$defs/Clip"
    },
    "ClipOut": {
      "$ref": "#/$defs/ClipOut"
    },
    "ClipType": {
      "$ref": "#/$defs/ClipType"
    },
    "CropWindow": {
      "$ref": "#/$defs/CropWindow"
    },
    "Job": {
      "$ref": "#/$defs/Job"
    },
    "JobStatus": {
      "$ref": "#/$defs/JobStatus"
    },
    "Metrics": {
      "$ref": "#/$defs/Metrics"
    },
    "Segment": {
      "$ref": "#/$defs/Segment"
    },
    "SourceKind": {
      "$ref": "#/$defs/SourceKind"
    },
    "Transcript": {
      "$ref": "#/$defs/Transcript"
    },
    "Word": {
      "$ref": "#/$defs/Word"
    }
  },
  "title": "ClipFlowContract",
  "type": "object"
}
